    "test:flow:warehouse": "bun run src/flow-testing-feature/test-flow-warehouse.ts",
    "test:flow:category": "bun run src/flow-testing-feature/test-flow-category.ts",
    "test:flow:uom": "bun run src/flow-testing-feature/test-flow-uom.ts",
